# Public port exposed by reverse proxy on Alibaba ECS host
PUBLIC_HTTP_PORT=80

# Public URL that browser will use (same URL serves frontend and /api via reverse proxy)
# Example with ECS public IP:
# NEXT_PUBLIC_BACKEND_BASE_URL=http://47.xx.xx.xx
# Example with domain:
# NEXT_PUBLIC_BACKEND_BASE_URL=https://your-domain.com
NEXT_PUBLIC_BACKEND_BASE_URL=http://YOUR_ECS_PUBLIC_IP

# Required Alibaba Cloud credentials
ALI_ACCESS_KEY=
ALI_SECRET_KEY=
ALI_ROLE_ARN=
OSS_REGION=oss-ap-southeast-1
OSS_BUCKET_NAME=
DASHSCOPE_API_KEY=

# Optional model overrides
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_EXTRACT_MODEL=qwen-vl-plus
DASHSCOPE_SUMMARY_MODEL=qwen-max
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_INDICATOR_MODEL=qwen-turbo

# Optional local fallback for chat logic (keep 0 on production)
CHAT_LOCAL_MOCK=0
